{
  "name": "@tamildesignsystem/react",
  "version": "0.1.4",
  "description": "Tamil-first React UI components, design tokens, and agent guidance for accessible Tamil interfaces.",
  "license": "MIT",
  "author": "Selva Toi",
  "homepage": "https://tamilui.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/selva-toi/Tamil_Design_System.git"
  },
  "bugs": {
    "url": "https://github.com/selva-toi/Tamil_Design_System/issues"
  },
  "keywords": [
    "tamil",
    "ui",
    "react",
    "components",
    "design-system",
    "accessibility",
    "templates",
    "government",
    "public-service",
    "tailwindcss"
  ],
  "type": "module",
  "sideEffects": [
    "./src/styles.css"
  ],
  "files": [
    "dist",
    "src/styles.css",
    "skills",
    "AGENTS.md",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./src/styles.css",
    "./skill": "./skills/tamil-ui-design/SKILL.md",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "peerDependencies": {
    "react": ">=18.3.0 || >=19.0.0",
    "react-dom": ">=18.3.0 || >=19.0.0",
    "tailwindcss": ">=4.0.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.14.0",
    "next-themes": "^0.4.6",
    "react-day-picker": "^10.0.0",
    "react-resizable-panels": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
